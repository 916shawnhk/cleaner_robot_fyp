<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

    <material name="white">
        <color rgba="1 1 1 1" />
    </material>

    <material name="black">
        <color rgba="0 0 0 1" />
    </material>

    <material name="red">
        <color rgba="1 0 0 1" />
    </material>

    <material name="yellow">
        <color rgba="1 1 0 1" />
    </material>

    <!-- BASE LINK -->
    <link name="base_link">

    </link>

    <!-- BODY -->
    <joint name="body_joint" type="fixed">
        <parent link="base_link" />
        <child link="body" />
        <origin xyz="-0.1 0 0" />
    </joint>
    <link name="body">
        <visual>
            <origin xyz="0.15 0 0.075" />
            <geometry>
                <box size="0.3 0.3 0.15" />
            </geometry>
            <material name="white"/>
        </visual>
        <collision>
            <origin xyz="0.15 0 0.075" />
            <geometry>
                <box size="0.3 0.3 0.15" />
            </geometry>
        </collision>
    </link>

    <!-- LEFT WHEEL -->
    <joint name="left_wheel_joint" type="continuous">
        <parent link="base_link"/>
        <child link="left_wheel"/>
        <!-- ROTATE Z-AXIS TO FACE OUTWARDS 
             BY DEFAULT CYLINDER LENGTH PARALLEL TO Z-AXIS -->
        <origin xyz="0 0.175 0" rpy="-${pi/2} 0 0"/>
        <!-- WHEEL ROTATE AROUND Z-AXIS 
             ANTICLOCKWISE TO MOVE FORWARD -->
        <axis xyz="0 0 1"/>
    </joint>
    <link name="left_wheel">
        <visual>
            <geometry>
                <cylinder radius="0.05" length="0.04"/>
            </geometry>
            <material name="black"/>
        </visual>
        <collision>
            <geometry>
                <cylinder radius="0.05" length="0.04"/>
            </geometry>
        </collision>
    </link>

    <!-- RIGHT WHEEL -->
    <joint name="right_wheel_joint" type="continuous">
        <parent link="base_link"/>
        <child link="right_wheel"/>
        <!-- ROTATE Z-AXIS TO FACE OUTWARDS 
             BY DEFAULT CYLINDER LENGTH PARALLEL TO Z-AXIS -->
        <origin xyz="0 -0.175 0" rpy="${pi/2} 0 0"/>
        <!-- WHEEL ROTATE AROUND Z-AXIS 
             ANTICLOCKWISE TO MOVE FORWARD -->
        <axis xyz="0 0 -1"/>
    </joint>
    <link name="right_wheel">
        <visual>
            <geometry>
                <cylinder radius="0.05" length="0.04"/>
            </geometry>
            <material name="black"/>
        </visual>
        <collision>
            <geometry>
                <cylinder radius="0.05" length="0.04"/>
            </geometry>
        </collision>
    </link>

    <!-- CASTER WHEEL -->
    <joint name="caster_wheel_joint" type="fixed">
        <parent link="body"/>
        <child link="caster_wheel"/>
        <origin xyz="0.24 0 0"/>
    </joint>
    <link name="caster_wheel">
        <visual>
            <geometry>
                <sphere radius="0.05"/>
            </geometry>
            <material name="black"/>
        </visual>
        <collision>
            <geometry>
                <sphere radius="0.05"/>
            </geometry>
        </collision>
    </link>

</robot>