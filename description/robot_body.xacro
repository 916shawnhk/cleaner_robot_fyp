<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

    <xacro:include filename="inertial_macros.xacro"/>

    <material name="white">
        <color rgba="1 1 1 1" />
    </material>

    <material name="black">
        <color rgba="0 0 0 1" />
    </material>

    <material name="gray">
        <color rgba="0.5 0.5 0.5 1" />
    </material>

    <material name="red">
        <color rgba="1 0 0 1" />
    </material>

    <material name="yellow">
        <color rgba="1 1 0 1" />
    </material>

    <material name="orange">
        <color rgba="1 0.65 0 1" />
    </material>

    <!-- BASE LINK -->
    <!-- let world origin at between centre of two wheels -->
    <link name="base_link">
        <xacro:inertial_box mass="0.0001" x="0.0001" y="0.0001" z="0.0001">
            <origin xyz="0 0 0" rpy="0 0 0" />
        </xacro:inertial_box>
    </link>


    <!-- BODY -->
    <joint name="body_joint" type="fixed">
        <parent link="base_link" />
        <child link="body" />
        <!-- joint at body's bottom rear-->
        <origin xyz="-0.05 0 -0.025" />
    </joint>
    <link name="body">
        <visual>
            <origin xyz="0.095 0 0.05" />
            <geometry>
                <box size="0.19 0.26 0.10" />
            </geometry>
            <material name="orange"/>
        </visual>
        <collision>
            <origin xyz="0.095 0 0.05" />
            <geometry>
                <box size="0.19 0.26 0.10" />
            </geometry>
        </collision>
        <xacro:inertial_box mass="1.2" x="0.19" y="0.26" z="0.1">
            <origin xyz="0.095 0 0.05" rpy="0 0 0" />
        </xacro:inertial_box>
    </link>

    <!-- LEFT WHEEL -->
    <joint name="left_wheel_joint" type="continuous">
        <parent link="base_link"/>
        <child link="left_wheel"/>
        <!-- ROTATE Z-AXIS TO FACE OUTWARDS 
             BY DEFAULT CYLINDER LENGTH PARALLEL TO Z-AXIS -->
        <origin xyz="0 0.1435 0" rpy="-${pi/2} 0 0"/>
        <!-- WHEEL ROTATE AROUND Z-AXIS 
             ANTICLOCKWISE TO MOVE FORWARD -->
        <axis xyz="0 0 1"/>
        <limit effort="50000" velocity="10"/>
        <!-- <dynamics damping="1.0" friction="1.0"/> -->
    </joint>
    <link name="left_wheel">
        <visual>
            <geometry>
                <cylinder radius="0.0335" length="0.027"/>
            </geometry>
            <material name="black"/>
        </visual>
        <collision>
            <geometry>
                <cylinder radius="0.0335" length="0.027"/>
            </geometry>
        </collision>
        <xacro:inertial_cylinder mass="0.05" radius="0.0335" length="0.027">
            <origin xyz="0 0 0" rpy="0 0 0" />
        </xacro:inertial_cylinder>
    </link>
    <!-- <transmission name="left_wheel_trans">
        <type>transmission_interface/SimpleTransmission</type>
        <actuator name="left_wheel_motor"/>
        <joint name="left_wheel_joint"/>
    </transmission> -->

    <!-- RIGHT WHEEL -->
    <joint name="right_wheel_joint" type="continuous">
        <parent link="base_link"/>
        <child link="right_wheel"/>
        <!-- ROTATE Z-AXIS TO FACE OUTWARDS 
             BY DEFAULT CYLINDER LENGTH PARALLEL TO Z-AXIS -->
        <origin xyz="0 -0.1435 0" rpy="${pi/2} 0 0"/>
        <!-- WHEEL ROTATE AROUND Z-AXIS 
             ANTICLOCKWISE TO MOVE FORWARD -->
        <axis xyz="0 0 -1"/>
        <limit effort="50000" velocity="10"/>
        <!-- <dynamics damping="1.0" friction="1.0"/> -->
    </joint>
    <link name="right_wheel">
        <visual>
            <geometry>
                <cylinder radius="0.0335" length="0.027"/>
            </geometry>
            <material name="black"/>
        </visual>
        <collision>
            <geometry>
                <cylinder radius="0.0335" length="0.027"/>
            </geometry>
        </collision>
        <xacro:inertial_cylinder mass="0.05" radius="0.0335" length="0.027">
            <origin xyz="0 0 0" rpy="0 0 0" />
        </xacro:inertial_cylinder>
    </link>
    <!-- <transmission name="right_wheel_trans">
        <type>transmission_interface/SimpleTransmission</type>
        <actuator name="right_wheel_motor"/>
        <joint name="right_wheel_joint"/>
    </transmission> -->

    <!-- CASTER WHEEL -->
    <joint name="caster_wheel_joint" type="fixed">
        <parent link="body"/>
        <child link="caster_wheel"/>
        <origin xyz="0.15 0 0"/>
    </joint>
    <link name="caster_wheel">
        <visual>
            <geometry>
                <sphere radius="0.0085"/>
            </geometry>
            <material name="black"/>
        </visual>
        <collision>
            <geometry>
                <sphere radius="0.0085"/>
            </geometry>
        </collision>
        <xacro:inertial_sphere mass="0.025" radius="0.0085">
            <origin xyz="0 0 0" rpy="0 0 0" />
        </xacro:inertial_sphere>
    </link>

</robot>