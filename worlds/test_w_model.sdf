    <!-- SUN -->
    <light name='sun' type='directional'>
      <pose>0 0 10 0 0 0</pose>
      <cast_shadows>true</cast_shadows>
      <intensity>1</intensity>
      <direction>-0.5 0.1 -0.9</direction>
      <diffuse>0.800000012 0.800000012 0.800000012 1</diffuse>
      <specular>0.200000003 0.200000003 0.200000003 1</specular>
      <attenuation>
        <range>1000</range><linear>0.01</linear>
        <constant>0.9</constant><quadratic>0.001</quadratic>
      </attenuation>
      <spot><inner_angle>0</inner_angle><outer_angle>0</outer_angle><falloff>0</falloff></spot>
    </light>

    <!--
    ================================================================
    ROBOT MODEL - native SDF (bypasses URDF->SDF conversion entirely)

    All link poses are in the model frame (= base_link frame).
    Derived from xacro joint chain:
      body_joint:         base_link + xyz="-0.05  0  -0.025"
      left_wheel_joint:   base_link + xyz="0  0.1435  0",  rpy="-pi/2 0 0"
      right_wheel_joint:  base_link + xyz="0 -0.1435  0",  rpy="+pi/2 0 0"
      caster_wheel_joint: body      + xyz="0.15 0 0"
                          -> base_link: (0.1, 0, -0.025)
      lidar_joint:        body      + xyz="0.09 0 0.1125"
                          -> base_link: (0.04, 0, 0.0875)
      camera_joint:       body      + xyz="0.19 0 0.045"
                          -> base_link: (0.14, 0, 0.02)

    Robot spawned at z=0.0335 so wheels sit on ground.
    ================================================================
    -->
    <model name='robot'>
      <pose>0 0 0.0335 0 0 0</pose>
      <self_collide>false</self_collide>

      <!-- DiffDrive plugin -->
      <plugin filename='gz-sim-diff-drive-system' name='gz::sim::systems::DiffDrive'>
        <left_joint>left_wheel_joint</left_joint>
        <right_joint>right_wheel_joint</right_joint>
        <wheel_separation>0.287</wheel_separation>
        <wheel_radius>0.0335</wheel_radius>
        <max_linear_acceleration>10</max_linear_acceleration>
        <max_linear_deceleration>10</max_linear_deceleration>
        <max_angular_deceleration>10</max_angular_deceleration>
        <topic>cmd_vel</topic>
        <tf_topic>/tf</tf_topic>
        <odom_topic>odom</odom_topic>
        <frame_id>odom</frame_id>
        <child_frame_id>base_link</child_frame_id>
        <odom_publisher_frequency>100</odom_publisher_frequency>
      </plugin>

      <!-- JointStatePublisher plugin -->
      <plugin filename='gz-sim-joint-state-publisher-system' name='gz::sim::systems::JointStatePublisher'>
        <topic>joint_states</topic>
        <joint_name>left_wheel_joint</joint_name>
        <joint_name>right_wheel_joint</joint_name>
      </plugin>

      <!-- Sensors system (required for gpu_lidar to work) -->
      <plugin filename='gz-sim-sensors-system' name='gz::sim::systems::Sensors'>
        <render_engine>ogre2</render_engine>
      </plugin>

      <!-- BASE LINK -->
      <link name='base_link'>
        <pose>0 0 0 0 0 0</pose>
        <inertial>
          <pose>0 0 0 0 0 0</pose>
          <mass>0.0001</mass>
          <inertia>
            <ixx>1.67e-13</ixx><ixy>0</ixy><ixz>0</ixz>
            <iyy>1.67e-13</iyy><iyz>0</iyz><izz>1.67e-13</izz>
          </inertia>
        </inertial>
      </link>

      <!-- BODY: link pose = body_joint origin = (-0.05, 0, -0.025) -->
      <link name='body'>
        <pose>-0.05 0 -0.025 0 0 0</pose>
        <inertial>
          <pose>0.095 0 0.05 0 0 0</pose>
          <mass>1.2</mass>
          <inertia>
            <ixx>0.007760</ixx><ixy>0</ixy><ixz>0</ixz>
            <iyy>0.004610</iyy><iyz>0</iyz><izz>0.010370</izz>
          </inertia>
        </inertial>
        <visual name='body_visual'>
          <pose>0.095 0 0.05 0 0 0</pose>
          <geometry><box><size>0.19 0.26 0.10</size></box></geometry>
          <material><ambient>1 0.65 0 1</ambient><diffuse>1 0.65 0 1</diffuse></material>
        </visual>
        <collision name='body_collision'>
          <pose>0.095 0 0.05 0 0 0</pose>
          <geometry><box><size>0.19 0.26 0.10</size></box></geometry>
        </collision>
      </link>
      <joint name='body_joint' type='fixed'>
        <parent>base_link</parent><child>body</child>
      </joint>

      <!-- LEFT WHEEL: pose (0, 0.1435, 0), rpy=(-pi/2, 0, 0) -->
      <link name='left_wheel'>
        <pose>0 0.1435 0 -1.5707963 0 0</pose>
        <inertial>
          <pose>0 0 0 0 0 0</pose>
          <mass>0.05</mass>
          <inertia>
            <ixx>0.00001707</ixx><ixy>0</ixy><ixz>0</ixz>
            <iyy>0.00001707</iyy><iyz>0</iyz><izz>0.00002806</izz>
          </inertia>
        </inertial>
        <visual name='left_wheel_visual'>
          <geometry><cylinder><radius>0.0335</radius><length>0.027</length></cylinder></geometry>
          <material><ambient>0 0 0 1</ambient><diffuse>0 0 0 1</diffuse></material>
        </visual>
        <collision name='left_wheel_collision'>
          <geometry><cylinder><radius>0.0335</radius><length>0.027</length></cylinder></geometry>
        </collision>
      </link>
      <joint name='left_wheel_joint' type='revolute'>
        <parent>base_link</parent><child>left_wheel</child>
        <axis>
          <xyz>0 0 1</xyz>
          <limit><effort>50000</effort><velocity>10</velocity></limit>
          <dynamics><damping>0</damping></dynamics>
        </axis>
      </joint>

      <!-- RIGHT WHEEL: pose (0, -0.1435, 0), rpy=(+pi/2, 0, 0) -->
      <link name='right_wheel'>
        <pose>0 -0.1435 0 1.5707963 0 0</pose>
        <inertial>
          <pose>0 0 0 0 0 0</pose>
          <mass>0.05</mass>
          <inertia>
            <ixx>0.00001707</ixx><ixy>0</ixy><ixz>0</ixz>
            <iyy>0.00001707</iyy><iyz>0</iyz><izz>0.00002806</izz>
          </inertia>
        </inertial>
        <visual name='right_wheel_visual'>
          <geometry><cylinder><radius>0.0335</radius><length>0.027</length></cylinder></geometry>
          <material><ambient>0 0 0 1</ambient><diffuse>0 0 0 1</diffuse></material>
        </visual>
        <collision name='right_wheel_collision'>
          <geometry><cylinder><radius>0.0335</radius><length>0.027</length></cylinder></geometry>
        </collision>
      </link>
      <joint name='right_wheel_joint' type='revolute'>
        <parent>base_link</parent><child>right_wheel</child>
        <axis>
          <xyz>0 0 -1</xyz>
          <limit><effort>50000</effort><velocity>10</velocity></limit>
          <dynamics><damping>0</damping></dynamics>
        </axis>
      </joint>

      <!-- CASTER WHEEL: body(-0.05,0,-0.025) + joint(0.15,0,0) = (0.1, 0, -0.025) -->
      <link name='caster_wheel'>
        <pose>0.1 0 -0.025 0 0 0</pose>
        <inertial>
          <pose>0 0 0 0 0 0</pose>
          <mass>0.025</mass>
          <inertia>
            <ixx>7.225e-7</ixx><ixy>0</ixy><ixz>0</ixz>
            <iyy>7.225e-7</iyy><iyz>0</iyz><izz>7.225e-7</izz>
          </inertia>
        </inertial>
        <visual name='caster_visual'>
          <geometry><sphere><radius>0.0085</radius></sphere></geometry>
          <material><ambient>0 0 0 1</ambient><diffuse>0 0 0 1</diffuse></material>
        </visual>
        <collision name='caster_collision'>
          <geometry><sphere><radius>0.0085</radius></sphere></geometry>
          <surface>
            <friction><ode><mu>0.001</mu><mu2>0.001</mu2></ode></friction>
          </surface>
        </collision>
      </link>
      <joint name='caster_wheel_joint' type='fixed'>
        <parent>body</parent><child>caster_wheel</child>
      </joint>

      <!--
      LIDAR FRAME: body(-0.05,0,-0.025) + joint(0.09,0,0.1125) = (0.04, 0, 0.0875)
      Sensor defined DIRECTLY on this link in native SDF.
      No URDF->SDF conversion => no lumping => sensor stays on lidar_frame.
      VisualizeLidar entity path: /world/empty/model/robot/link/lidar_frame/sensor/lidar/scan
      -->
      <link name='lidar_frame'>
        <pose>0.04 0 0.0875 0 0 0</pose>
        <inertial>
          <pose>0 0 0 0 0 0</pose>
          <mass>0.15</mass>
          <inertia>
            <ixx>0.00004385</ixx><ixy>0</ixy><ixz>0</ixz>
            <iyy>0.00004385</iyy><iyz>0</iyz><izz>0.00007207</izz>
          </inertia>
        </inertial>
        <visual name='lidar_visual'>
          <geometry><cylinder><radius>0.031</radius><length>0.025</length></cylinder></geometry>
          <material><ambient>1 0 0 1</ambient><diffuse>1 0 0 1</diffuse></material>
        </visual>
        <collision name='lidar_collision'>
          <geometry><cylinder><radius>0.031</radius><length>0.025</length></cylinder></geometry>
        </collision>

        <sensor name='lidar' type='gpu_lidar'>
          <pose>0 0 0 0 0 0</pose>
          <update_rate>10</update_rate>
          <always_on>true</always_on>
          <visualize>true</visualize>
          <!-- <topic>/scan</topic> -->
          <!-- <topic>/lidar_raw</topic> -->
          <lidar>
            <scan>
              <horizontal>
                <samples>720</samples>
                <resolution>1</resolution>
                <min_angle>-3.14159</min_angle>
                <max_angle>3.14159</max_angle>
              </horizontal>
            </scan>
            <range>
              <min>0.15</min>
              <max>10.0</max>
              <resolution>0.01</resolution>
            </range>
            <noise>
              <type>gaussian</type>
              <mean>0.0</mean>
              <stddev>0.01</stddev>
            </noise>
          </lidar>
        </sensor>
      </link>
      <joint name='lidar_joint' type='fixed'>
        <parent>body</parent><child>lidar_frame</child>
      </joint>

      <!-- CAMERA LINK: body(-0.05,0,-0.025) + joint(0.19,0,0.045) = (0.14, 0, 0.02) -->
      <link name='camera_link'>
        <pose>0.14 0 0.02 0 0 0</pose>
        <visual name='camera_visual'>
          <geometry><box><size>0.005 0.024 0.018</size></box></geometry>
          <material><ambient>1 0 0 1</ambient><diffuse>1 0 0 1</diffuse></material>
        </visual>
      </link>
      <joint name='camera_joint' type='fixed'>
        <parent>body</parent><child>camera_link</child>
      </joint>

      <!-- CAMERA OPTICAL LINK: same xyz as camera_link, rpy=(-pi/2, 0, -pi/2) -->
      <link name='camera_optical_link'>
        <pose>0.14 0 0.02 -1.5707963 0 -1.5707963</pose>
      </link>
      <joint name='camera_optical_joint' type='fixed'>
        <parent>camera_link</parent><child>camera_optical_link</child>
      </joint>

    </model>

    <!-- GUI PLUGINS -->
    <gui fullscreen="0">
      <plugin filename="MinimalScene" name="3D View">
        <gz-gui>
          <title>3D View</title>
          <property type="bool" key="showTitleBar">false</property>
          <property type="string" key="state">docked</property>
        </gz-gui>
        <engine>ogre2</engine>
        <scene>scene</scene>
        <ambient_light>0.4 0.4 0.4</ambient_light>
        <background_color>0.8 0.8 0.8</background_color>
      </plugin>
      <plugin filename="GzSceneManager" name="Scene Manager">
        <gz-gui>
          <property key="resizable" type="bool">false</property>
          <property key="width" type="double">5</property>
          <property key="height" type="double">5</property>
          <property key="state" type="string">floating</property>
          <property key="showTitleBar" type="bool">false</property>
        </gz-gui>
      </plugin>
      <plugin filename="InteractiveViewControl" name="Interactive view control">
        <gz-gui>
          <property key="resizable" type="bool">false</property>
          <property key="width" type="double">5</property>
          <property key="height" type="double">5</property>
          <property key="state" type="string">floating</property>
          <property key="showTitleBar" type="bool">false</property>
        </gz-gui>
      </plugin>
      <plugin filename="CameraTracking" name="Camera tracking">
        <gz-gui>
          <property key="resizable" type="bool">false</property>
          <property key="width" type="double">5</property>
          <property key="height" type="double">5</property>
          <property key="state" type="string">floating</property>
          <property key="showTitleBar" type="bool">false</property>
        </gz-gui>
      </plugin>
      <plugin filename="MarkerManager" name="Marker manager">
        <gz-gui>
          <property key="resizable" type="bool">false</property>
          <property key="width" type="double">5</property>
          <property key="height" type="double">5</property>
          <property key="state" type="string">floating</property>
          <property key="showTitleBar" type="bool">false</property>
        </gz-gui>
      </plugin>
      <plugin filename="SelectEntities" name="Select entities">
        <gz-gui>
          <property key="resizable" type="bool">false</property>
          <property key="width" type="double">5</property>
          <property key="height" type="double">5</property>
          <property key="state" type="string">floating</property>
          <property key="showTitleBar" type="bool">false</property>
        </gz-gui>
      </plugin>
      <plugin filename="VisualizationCapabilities" name="Visualization capabilities">
        <gz-gui>
          <property key="resizable" type="bool">false</property>
          <property key="width" type="double">5</property>
          <property key="height" type="double">5</property>
          <property key="state" type="string">floating</property>
          <property key="showTitleBar" type="bool">false</property>
        </gz-gui>
      </plugin>
      <plugin filename="Spawn" name="Spawn Entities">
        <gz-gui>
          <property key="resizable" type="bool">false</property>
          <property key="width" type="double">5</property>
          <property key="height" type="double">5</property>
          <property key="state" type="string">floating</property>
          <property key="showTitleBar" type="bool">false</property>
        </gz-gui>
      </plugin>
      <plugin filename="EntityContextMenuPlugin" name="Entity context menu">
        <gz-gui>
          <property key="resizable" type="bool">false</property>
          <property key="width" type="double">5</property>
          <property key="height" type="double">5</property>
          <property key="state" type="string">floating</property>
          <property key="showTitleBar" type="bool">false</property>
        </gz-gui>
      </plugin>
      <plugin filename="WorldControl" name="World control">
        <gz-gui>
          <title>World control</title>
          <property type="bool" key="showTitleBar">false</property>
          <property type="bool" key="resizable">false</property>
          <property type="double" key="height">72</property>
          <property type="double" key="z">1</property>
          <property type="string" key="state">floating</property>
          <anchors target="3D View">
            <line own="left" target="left"/>
            <line own="bottom" target="bottom"/>
          </anchors>
        </gz-gui>
        <play_pause>true</play_pause>
        <step>true</step>
        <start_paused>false</start_paused>
      </plugin>
      <plugin filename="WorldStats" name="World stats">
        <gz-gui>
          <title>World stats</title>
          <property type="bool" key="showTitleBar">false</property>
          <property type="bool" key="resizable">false</property>
          <property type="double" key="height">110</property>
          <property type="double" key="z">1</property>
          <property type="string" key="state">floating</property>
          <anchors target="3D View">
            <line own="right" target="right"/>
            <line own="bottom" target="bottom"/>
          </anchors>
        </gz-gui>
        <sim_time>true</sim_time>
        <real_time>true</real_time>
        <real_time_factor>true</real_time_factor>
        <iterations>true</iterations>
      </plugin>
      <plugin filename="EntityTree" name="Entity tree">
        <gz-gui>
          <property type="string" key="state">docked</property>
        </gz-gui>
      </plugin>
      <plugin filename="TransformControl" name="Transform control">
        <gz-gui>
          <property key="resizable" type="bool">false</property>
          <property key="width" type="double">5</property>
          <property key="height" type="double">5</property>
          <property key="state" type="string">floating</property>
          <property key="showTitleBar" type="bool">false</property>
        </gz-gui>
      </plugin>

      <!--
        VisualizeLidar: sensor is on lidar_frame link (native SDF, no lumping).
        Full scoped internal Gazebo topic for entity lookup:
        /world/empty/model/robot/link/lidar_frame/sensor/lidar/scan
      -->
      <plugin filename="VisualizeLidar" name="Visualize lidar">
        <gz-gui>
          <title>Visualize lidar</title>
          <property type="string" key="state">docked</property>
        </gz-gui>
        <!-- <topic>/scan</topic> -->
        <!-- <topic>/lidar_raw</topic> -->
        <topic>/world/empty/model/robot/link/base_link/sensor/lidar/scan</topic>
        <visualize_non_hitting>false</visualize_non_hitting>
      </plugin>

    </gui>

  </world>
</sdf>