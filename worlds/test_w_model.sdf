    </include>
    <include>
      <uri>file:///home/cj-ubuntu/.gz/fuel/fuel.gazebosim.org/openrobotics/models/pallet_standard/1</uri>
      <name>Pallet_Standard</name>
      <pose>-2.1786058045799335 1.7454288262896998 0 0 0 0</pose>
    </include>
    <include>
      <uri>file:///home/cj-ubuntu/.gz/fuel/fuel.gazebosim.org/openrobotics/models/pallet_standard/1</uri>
      <name>Pallet_Standard_0</name>
      <pose>0.91305782552453918 -3.9513962275363665 0 0 0 0</pose>
    </include>
    <include>
      <uri>file:///home/cj-ubuntu/.gz/fuel/fuel.gazebosim.org/openrobotics/models/pallet_jack/1</uri>
