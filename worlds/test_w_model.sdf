      <uri>file:///home/cj-ubuntu/.gz/fuel/fuel.gazebosim.org/openrobotics/models/construction cone/3</uri>
      <name>Construction Cone_0</name>
      <pose>-1.2032152005925623 -2.395862419635455 0 0 0 0</pose>
    </include>
    <include>
      <uri>file:///home/cj-ubuntu/.gz/fuel/fuel.gazebosim.org/openrobotics/models/construction cone/3</uri>
      <name>Construction Cone_1</name>
      <pose>2.8940107827621282 -2.1896560025575695 0 0 0 0</pose>
    </include>
    <include>
      <uri>file:///home/cj-ubuntu/.gz/fuel/fuel.gazebosim.org/openrobotics/models/construction cone/3</uri>
      <name>Construction Cone_2</name>
