      <pose>0.63707224096422266 1.3692018234985848 0 0 0 0</pose>
    </include>
    <include>
      <uri>file:///home/cj-ubuntu/.gz/fuel/fuel.gazebosim.org/openrobotics/models/pallet_rack/1</uri>
      <name>Pallet_Rack</name>
      <pose>4.1118655540621916 0.34556748715034979 0 0 0 0</pose>
    </include>
    <include>
      <uri>file:///home/cj-ubuntu/.gz/fuel/fuel.gazebosim.org/openrobotics/models/construction cone/3</uri>
      <name>Construction Cone</name>
      <pose>-1.0183477764022906 0.37907605809035921 0 0 0 0</pose>
    </include>
